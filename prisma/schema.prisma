generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Ingredient {
  id           String   @id @default(cuid())
  name         String   @unique
  category     String   // vegetables | fruits | grains | protein | dairy | oils | spices | other
  kcalPer100g  Float?
  proteinPer100g Float?
  carbsPer100g   Float?
  fatPer100g     Float?
  fiberPer100g   Float?
  // Package size for waste prevention (e.g., coconut milk = 400g can)
  packageSizeG  Float?
  packageUnit   String?  // can | bottle | bag | bunch | pack
  packageLabel  String?  // "karton 10 szt.", "puszka 400ml"
  pieceWeightG  Float?   // grams per piece — set for count-sold items (egg=60g)
  // Hint unit for recipe display: "340 g (~2 szt.)" or "42 g (~3 łyżki)"
  hintUnitG     Float?   // grams per hint unit (e.g. 180 for tomato, 14 for tbsp oil)
  hintUnit      String?  // unit name: "szt." | "łyżka" | "łyżeczka" | "ząbek" | "główka"
  recipeIngredients RecipeIngredient[]
  createdAt    DateTime @default(now())
}

model Recipe {
  id             String   @id @default(cuid())
  name           String
  // breakfast | lunch | dinner | snack | cocktail
  type           String
  prepTimeMin    Int?
  cookTimeMin    Int?
  batchFriendly  Boolean  @default(false)
  maxStorageDays Int      @default(1)
  // Macros per 1 serving (as eaten, not per 100g)
  kcalPerServing   Float?
  proteinG         Float?
  carbsG           Float?
  fatG             Float?
  fiberG           Float?
  instructions   String   @default("[]") // JSON array of steps
  sourceDiet     String?  // filename of origin diet
  tags           String   @default("[]") // JSON array
  // Recipe metadata
  baseServings      Int     @default(1)            // portions this recipe yields
  ingredientBasis   String  @default("per-serving") // "per-serving" | "per-whole"
  source            String  @default("dietitian")   // "dietitian" | "user"
  nutritionVerified Boolean @default(false)          // true = macros are reliable
  ingredients    RecipeIngredient[]
  mealPlanMeals  MealPlanMeal[]
  createdAt      DateTime @default(now())

  @@unique([name, sourceDiet])
}

model RecipeIngredient {
  id             String     @id @default(cuid())
  recipeId       String
  recipe         Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredientId   String
  ingredient     Ingredient @relation(fields: [ingredientId], references: [id])
  amountG        Float      // total grams for 1 serving
  displayText    String?    // original text e.g. "3 łyżki oliwy (30g)"
  scalesLinearly Boolean    @default(true) // false for oils, spices
}

model MealPlan {
  id        String   @id @default(cuid())
  name      String   @default("Tydzień")
  weekStart DateTime
  status    String   @default("draft") // draft | active | archived
  meals     MealPlanMeal[]
  createdAt DateTime @default(now())
}

model MealPlanMeal {
  id           String    @id @default(cuid())
  mealPlanId   String
  mealPlan     MealPlan  @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  // 1=Mon ... 7=Sun
  dayOfWeek    Int
  mealType     String    // breakfast | lunch | dinner | snack
  recipeId     String
  recipe       Recipe    @relation(fields: [recipeId], references: [id])
  servings     Float     @default(1.0)
  // Batch cooking — meals with same batchGroupId are cooked together once
  batchGroupId String?
  batchDayNum  Int?      // 1, 2, 3 — freshness day within the batch
}

model HealthLog {
  id            String   @id @default(cuid())
  date          String   @unique // YYYY-MM-DD — no timezone issues
  // Routine checklists — JSON arrays of completed item IDs
  morningDone   String   @default("[]")
  eveningDone   String   @default("[]")
  // Daily metrics
  waterGlasses  Int?
  sleepH        Float?
  sleepQuality  Int?     // 1-5
  energyLevel   Int?     // 1-5
  moodLevel     Int?     // 1-5
  // 1% Strategy daily points (1-3 per category)
  pointsDiet    Int?
  pointsSupp    Int?
  pointsTrain   Int?
  pointsRoutine Int?
  pointsRelax   Int?
  pointsMindset Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AppSettings {
  id                 String   @id @default("default")
  personAName        String   @default("Michał")
  personAKcal        Int      @default(2500)
  personBName        String   @default("Osoba B")
  personBKcal        Int      @default(1800)
  defaultBatchConfig String   @default("") // JSON-encoded BatchConfig, empty = use app default
  updatedAt          DateTime @updatedAt
}
